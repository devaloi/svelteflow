{
	"name": "svelteflow",
	"version": "1.0.0",
	"private": true,
	"description": "Analytics dashboard built with SvelteKit — SSR with streaming, real-time SSE, Chart.js visualizations",
	"repository": {
		"type": "git",
		"url": "https://github.com/devaloi/svelteflow.git"
	},
	"license": "MIT",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:unit": "vitest run",
		"test:e2e": "playwright test",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"seed": "vite-node src/lib/server/seed.ts",
		"migrate": "drizzle-kit migrate",
		"generate": "drizzle-kit generate"
	},
	"devDependencies": {
		"@playwright/test": "^1.52.0",
		"@sveltejs/adapter-node": "^5.2.0",
		"@sveltejs/kit": "^2.21.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tailwindcss/vite": "^4.1.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/bcryptjs": "^2.4.6",
		"drizzle-kit": "^0.31.0",
		"eslint": "^9.27.0",
		"eslint-config-prettier": "^10.1.0",
		"eslint-plugin-svelte": "^3.5.0",
		"globals": "^16.1.0",
		"prettier": "^3.5.0",
		"prettier-plugin-svelte": "^3.3.0",
		"svelte": "^5.33.0",
		"svelte-check": "^4.2.0",
		"tailwindcss": "^4.1.0",
		"typescript": "^5.7.0",
		"typescript-eslint": "^8.32.0",
		"vite": "^6.3.0",
		"vite-node": "^3.2.0",
		"vitest": "^3.2.0"
	},
	"dependencies": {
		"bcryptjs": "^2.4.3",
		"better-sqlite3": "^11.9.0",
		"chart.js": "^4.4.0",
		"drizzle-orm": "^0.44.0"
	},
	"type": "module"
}
